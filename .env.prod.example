# Production hosted stack secrets — copy to .env.prod, fill in real values,
# never commit .env.prod to git.
#
# Used by: docker-compose.prod.yml
# For self-hosted single-instance SQLite deployments, use .env.example instead.

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=responsibleai
POSTGRES_USER=rai_user
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_-hex_32

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_generate_with_openssl_rand_-hex_32

# ── Application ───────────────────────────────────────────────────────────────
RAI_API_KEYS=CHANGE_ME_or_use_org-scoped_DB_keys_instead
RAI_ALLOWED_ORIGINS=https://your-dashboard.example.com
RAI_ALERT_THRESHOLD=5.0
RAI_MONTHLY_BUDGET_USD=10000.0
RAI_WORKERS=4

# ── SSO / OIDC (optional) ───────────────────────────────────────────────────────
# RAI_OIDC_ISSUER=https://your-idp.example.com
# RAI_OIDC_CLIENT_ID=
# RAI_OIDC_CLIENT_SECRET=
# RAI_OIDC_REDIRECT_URI=https://your-dashboard.example.com/api/auth/callback

# ── Stripe billing (required to sell PRO/ENTERPRISE plans) ─────────────────────
# RAI_STRIPE_SECRET_KEY=sk_live_...
# RAI_STRIPE_WEBHOOK_SECRET=whsec_...
# RAI_STRIPE_PRICE_ID_PRO=price_...
# RAI_STRIPE_PRICE_ID_ENTERPRISE=price_...
# RAI_BILLING_SUCCESS_URL=https://your-dashboard.example.com/billing/success
# RAI_BILLING_CANCEL_URL=https://your-dashboard.example.com/billing/cancel

# ── Telemetry (optional) ────────────────────────────────────────────────────────
# RAI_OTEL_ENDPOINT=http://otel-collector:4318
# RAI_OTEL_SERVICE_NAME=responsibleai-prod
