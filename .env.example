# ResponsibleAI — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Absolute path for persistent SQLite storage.
# Use :memory: for stateless/test environments.
RAI_DB_PATH=/data/responsibleai.db

# PostgreSQL (optional — leave unset to use SQLite above).
# When set, RAI_DB_PATH is ignored. Enables horizontal scaling.
# RAI_DATABASE_URL=postgresql://rai_user:secret@db-host:5432/responsibleai

# ── Redis ─────────────────────────────────────────────────────────────────────
# Distributed rate limiting (optional — in-memory when unset).
# Required for multi-replica deployments.
# RAI_REDIS_URL=redis://redis-host:6379/0

# ── OpenTelemetry APM ────────────────────────────────────────────────────────
# OTLP HTTP endpoint — unset to disable (no performance cost).
# Compatible with Datadog, Grafana Tempo, Jaeger, and any OTLP collector.
# RAI_OTEL_ENDPOINT=http://otel-collector:4318
# RAI_OTEL_SERVICE_NAME=responsibleai
# RAI_OTEL_HEADERS=DD-API-KEY=your-datadog-key

# ── Authentication ────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys.
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
RAI_API_KEYS=your-api-key-here,optional-second-key

# Set to false to disable auth (development only — never in production).
RAI_AUTH_ENABLED=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RAI_RATE_LIMIT_DEFAULT=100/minute
RAI_RATE_LIMIT_EVALUATE=30/minute

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the dashboard UI.
RAI_ALLOWED_ORIGINS=https://your-dashboard.example.com,http://localhost:8765

# Set to true only for development/demo environments.
RAI_ALLOW_ALL_ORIGINS=false

# ── Governance Thresholds ────────────────────────────────────────────────────
# Point drop in overall trust score that triggers a DriftAlert.
RAI_ALERT_THRESHOLD=5.0

# Monthly AI spending limit in USD for budget enforcement.
RAI_MONTHLY_BUDGET_USD=10000.0

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
RAI_LOG_LEVEL=INFO

# true = structured JSON (recommended for production / log aggregators)
# false = human-readable console output (development)
RAI_LOG_JSON=true

# ── Server ────────────────────────────────────────────────────────────────────
RAI_HOST=0.0.0.0
RAI_PORT=8765
RAI_WORKERS=1
